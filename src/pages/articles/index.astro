---
/**
 * 文章列表页 - /articles
 * 显示所有已发布的文章
 *
 * 优化：启用静态预渲染，构建时获取数据，运行时零数据库查询
 */
export const prerender = true;

import Layout from '../../layout/Layout.astro';
import { getArticles } from '../../lib/articles';
import ArticleCard from '../../components/ArticleCard.astro';
import MainNav from '../../components/MainNav.astro';
import CollectionPageShell from '../../components/CollectionPageShell.astro';
import CollectionEmptyState from '../../components/CollectionEmptyState.astro';

const articles = await getArticles();
---

<Layout
  title="所有文章 - Openeducation"
  description={`浏览 Openeducation 全部已发布文章（当前 ${articles.length} 篇）`}
>
  <MainNav />

  <CollectionPageShell
    icon="📝"
    title="所有文章"
    subtitle="按公开发布状态汇总的内容目录"
    meta={`共 ${articles.length} 篇文章`}
    quickLinks={[
      { href: '/categories', label: '学科分类' },
      { href: '/tags', label: '标签' },
      { href: '/blog', label: '最近更新' },
    ]}
  >
    {articles.length > 0 ? (
      <section class="collection-articles-section" aria-label="所有文章列表">
        <div class="collection-articles-grid">
          {articles.map((article) => (
            <ArticleCard article={article} />
          ))}
        </div>
      </section>
    ) : (
      <CollectionEmptyState
        message="暂无文章"
        actionHref="/blog"
        actionLabel="查看最近更新"
      />
    )}
  </CollectionPageShell>
</Layout>
