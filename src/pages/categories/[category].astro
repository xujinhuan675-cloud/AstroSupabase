---
/**
 * 学科分类文章列表页 - 静态生成版本
 *
 * 优化策略：
 * 1. 所有数据在构建时通过 getStaticPaths() 获取
 * 2. 运行时零数据库查询
 * 3. 与标签/文章列表页统一集合页结构
 */
export const prerender = true;

import Layout from '../../layout/Layout.astro';
import MainNav from '../../components/MainNav.astro';
import { getArticles } from '../../lib/articles';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCategoryInfo, getAllCategories, type CategoryInfo } from '../../lib/categories';
import CollectionPageShell from '../../components/CollectionPageShell.astro';
import CollectionEmptyState from '../../components/CollectionEmptyState.astro';
import type { Article } from '../../db/schema';

interface CategoryPageProps {
  currentCategory: CategoryInfo;
  articles: Article[];
}

export async function getStaticPaths() {
  console.log('[BUILD] Starting static path generation for categories...');

  const categories = getAllCategories();
  const paths = await Promise.all(categories.map(async (category) => {
    const categoryInfo = getCategoryInfo(category);
    const categoryArticles = await getArticles(undefined, category);

    return {
      params: { category },
      props: {
        currentCategory: categoryInfo!,
        articles: categoryArticles,
      } as CategoryPageProps,
    };
  }));

  console.log(`[BUILD] Category static paths generated for ${categories.length} categories`);
  return paths;
}

const { currentCategory, articles } = Astro.props as CategoryPageProps;
---

<Layout
  title={`${currentCategory.name} - 学科分类 - Openeducation`}
  description={`${currentCategory.name}：${currentCategory.description}，共 ${articles.length} 篇文章`}
>
  <MainNav />

  <CollectionPageShell
    backHref="/categories"
    backLabel="返回学科分类"
    icon={currentCategory.icon}
    title={currentCategory.name}
    subtitle={currentCategory.description}
    meta={`共 ${articles.length} 篇文章`}
    quickLinks={[
      { href: '/articles', label: '全部文章' },
      { href: '/tags', label: '标签' },
    ]}
  >
    {articles.length > 0 ? (
      <section class="collection-articles-section" aria-label={`${currentCategory.name} 分类下的文章列表`}>
        <div class="collection-articles-grid">
          {articles.map((article) => (
            <ArticleCard article={article} />
          ))}
        </div>
      </section>
    ) : (
      <CollectionEmptyState
        message="该分类暂无文章"
        actionHref="/blog"
        actionLabel="浏览所有文章"
      />
    )}
  </CollectionPageShell>
</Layout>
