---
/**
 * 学科分类导航页 - 静态生成版本
 *
 * 优化策略：
 * 1. 构建时聚合分类文章数量（单次查询）
 * 2. 运行时零数据库查询
 * 3. 接入 CollectionPageShell 保持集合页视觉节奏一致
 */
export const prerender = true;

import Layout from '../../layout/Layout.astro';
import MainNav from '../../components/MainNav.astro';
import CollectionPageShell from '../../components/CollectionPageShell.astro';
import { db } from '../../db/client';
import { articles } from '../../db/schema';
import { and, eq, sql } from 'drizzle-orm';
import { getAllCategories, getCategoryInfo, type Category } from '../../lib/categories';

const CATEGORY_COLORS: Record<Category, string> = {
  math: '#3B82F6',
  physics: '#8B5CF6',
  chemistry: '#10B981',
  biology: '#EF4444',
  computer: '#F59E0B',
  literature: '#EC4899',
};

const categoryRows = await db
  .select({
    category: articles.category,
    count: sql<number>`count(*)::int`,
  })
  .from(articles)
  .where(and(
    eq(articles.status, 'published'),
    eq(articles.isDeleted, false)
  ))
  .groupBy(articles.category);

const categoryCountMap = new Map<string, number>();
for (const row of categoryRows) {
  if (row.category) {
    categoryCountMap.set(row.category, Number(row.count));
  }
}

const categoryCards = getAllCategories().map((id) => {
  const info = getCategoryInfo(id)!;
  return {
    id,
    ...info,
    color: CATEGORY_COLORS[id],
    articleCount: categoryCountMap.get(id) ?? 0,
  };
});

const totalArticles = categoryCards.reduce((sum, item) => sum + item.articleCount, 0);
---

<Layout
  title="学科分类 - Openeducation"
  description="按学科浏览 Openeducation 的已发布文章与知识文档"
>
  <MainNav />

  <CollectionPageShell
    icon="🧭"
    title="学科分类"
    subtitle="按学科组织的知识入口"
    meta={`共 ${categoryCards.length} 个分类，${totalArticles} 篇文章`}
    quickLinks={[
      { href: '/articles', label: '全部文章' },
      { href: '/tags', label: '标签' },
      { href: '/blog', label: '最近更新' },
    ]}
  >
    <section class="taxonomy-section" aria-label="分类列表">
      <h2 class="taxonomy-section-title">全部分类</h2>
      <div class="taxonomy-grid">
        {categoryCards.map((category) => (
          <a
            href={`/categories/${category.id}`}
            class="taxonomy-card category-card"
            style={`--taxonomy-accent: ${category.color}`}
            aria-label={`进入 ${category.name} 分类，共 ${category.articleCount} 篇文章`}
          >
            <div class="taxonomy-card-head">
              <span class="taxonomy-icon" aria-hidden="true">{category.icon}</span>
              <h2 class="taxonomy-name">{category.name}</h2>
            </div>

            <p class="taxonomy-description">{category.description}</p>

            <div class="taxonomy-meta">
              <span class="taxonomy-count">{category.articleCount} 篇文章</span>
              {category.articleCount === 0 && (
                <span class="taxonomy-empty-hint">待更新</span>
              )}
            </div>
          </a>
        ))}
      </div>
    </section>
  </CollectionPageShell>
</Layout>

<style>
  .taxonomy-section {
    margin-bottom: 1.75rem;
  }

  .taxonomy-section-title {
    margin: 0 0 0.875rem;
    color: var(--dark);
    font-size: 1.125rem;
    font-weight: 700;
  }

  .taxonomy-grid {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .taxonomy-card {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    padding: 1.25rem;
    background: var(--light);
    border: 1px solid var(--lightgray);
    border-radius: 0.875rem;
    text-decoration: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
  }

  .taxonomy-card:hover {
    border-color: var(--taxonomy-accent);
    box-shadow: 0 10px 26px rgba(0, 0, 0, 0.08);
    transform: translateY(-2px);
  }

  .taxonomy-card:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--taxonomy-accent) 45%, transparent);
    outline-offset: 2px;
  }

  .taxonomy-card-head {
    display: flex;
    align-items: center;
    gap: 0.625rem;
  }

  .taxonomy-icon {
    font-size: 1.5rem;
    line-height: 1;
  }

  .taxonomy-name {
    margin: 0;
    color: var(--dark);
    font-size: 1.15rem;
    font-weight: 700;
    line-height: 1.3;
  }

  .taxonomy-description {
    margin: 0;
    color: var(--gray);
    line-height: 1.55;
    font-size: 0.95rem;
    flex-grow: 1;
  }

  .taxonomy-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: auto;
  }

  .taxonomy-count {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--taxonomy-accent);
  }

  .taxonomy-empty-hint {
    font-size: 0.75rem;
    color: var(--gray);
    background: var(--highlight);
    padding: 0.125rem 0.4rem;
    border-radius: 9999px;
  }

  @media (max-width: 1023px) {
    .taxonomy-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 767px) {
    .taxonomy-section-title {
      font-size: 1rem;
    }
    .taxonomy-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
  }
</style>
