---
export const prerender = false;
import Layout from '../../../layout/Layout.astro';

const accessToken = Astro.url.searchParams.get("access_token");
const refreshToken = Astro.url.searchParams.get("refresh_token");
const error = Astro.url.searchParams.get("error");

if (error) {
  return Astro.redirect(`/auth/login?error=${error}`);
}

if (!accessToken) {
  return Astro.redirect("/auth/login?error=" + encodeURIComponent("登录失败"));
}
---

<Layout title="微信登录">
  <main class="min-h-screen bg-gray-50 flex flex-col justify-center py-12 sm:px-6 lg:px-8">
    <div class="sm:mx-auto sm:w-full sm:max-w-md">
      <div class="bg-white py-8 px-4 shadow sm:rounded-lg sm:px-10 text-center">
        <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-indigo-600 mx-auto mb-4"></div>
        <h2 class="text-xl font-semibold text-gray-900 mb-2">微信登录中...</h2>
        <p class="text-sm text-gray-600">请稍候，正在完成登录</p>
      </div>
    </div>
  </main>

  <script>
    import { createClient } from '@supabase/supabase-js';

    // 从 URL 获取参数
    const urlParams = new URLSearchParams(window.location.search);
    const accessToken = urlParams.get('access_token');
    const refreshToken = urlParams.get('refresh_token');

    if (!accessToken || !refreshToken) {
      window.location.href = '/auth/login?error=' + encodeURIComponent('登录失败');
    } else {
      const supabase = createClient(
        import.meta.env.PUBLIC_SUPABASE_URL,
        import.meta.env.PUBLIC_SUPABASE_ANON_KEY
      );

      async function completeLogin() {
        try {
          console.log('开始设置会话...');
          
          // 设置 session
          const { data, error } = await supabase.auth.setSession({
            access_token: accessToken,
            refresh_token: refreshToken
          });

          if (error) {
            console.error('设置会话失败:', error);
            window.location.href = '/auth/login?error=' + encodeURIComponent('登录失败: ' + error.message);
            return;
          }

          console.log('会话设置成功:', data);
          
          // 登录成功，跳转到首页
          window.location.href = '/';
        } catch (err) {
          console.error('登录错误:', err);
          window.location.href = '/auth/login?error=' + encodeURIComponent('登录失败');
        }
      }

      // 页面加载后立即执行
      completeLogin();
    }
  </script>
</Layout>
