---
/**
 * 标签索引页 - /tags
 * 显示所有标签和每个标签的文章数量
 *
 * 优化：
 * 1. 启用静态预渲染，构建时获取数据，运行时零数据库查询
 * 2. 只统计已发布且未删除文章
 * 3. 接入 CollectionPageShell 统一视觉节奏
 */
export const prerender = true;

import Layout from '../../layout/Layout.astro';
import MainNav from '../../components/MainNav.astro';
import CollectionPageShell from '../../components/CollectionPageShell.astro';
import CollectionEmptyState from '../../components/CollectionEmptyState.astro';
import { db } from '../../db/client';
import { articleTags, articles as articlesTable } from '../../db/schema';
import { and, eq, sql } from 'drizzle-orm';

interface TagCount {
  tag: string;
  count: number;
}

const tagCountsResult = await db
  .select({
    tag: articleTags.tag,
    count: sql<number>`count(distinct ${articleTags.articleId})::int`.as('count'),
  })
  .from(articleTags)
  .innerJoin(articlesTable, eq(articleTags.articleId, articlesTable.id))
  .where(and(
    eq(articlesTable.status, 'published'),
    eq(articlesTable.isDeleted, false)
  ))
  .groupBy(articleTags.tag);

const tagCounts: TagCount[] = tagCountsResult
  .map((row) => ({ tag: row.tag, count: Number(row.count) }))
  .sort((a, b) => b.count - a.count);

const articlesCount = await db
  .select({ count: sql<number>`count(*)::int` })
  .from(articlesTable)
  .where(and(
    eq(articlesTable.status, 'published'),
    eq(articlesTable.isDeleted, false)
  ))
  .then((result) => Number(result[0]?.count || 0));

const tagsByAlpha = [...tagCounts].sort((a, b) => a.tag.localeCompare(b.tag, 'zh-CN'));
const popularTags = tagCounts.slice(0, 10);
const maxPopularCount = popularTags[0]?.count ?? 1;
---

<Layout
  title="标签 - Openeducation"
  description="按标签浏览 Openeducation 的已发布文章与知识文档"
>
  <MainNav />

  <CollectionPageShell
    icon="🏷️"
    title="标签"
    subtitle="按主题关键词聚合的知识入口"
    meta={`共 ${tagCounts.length} 个标签，${articlesCount} 篇文章`}
    quickLinks={[
      { href: '/articles', label: '全部文章' },
      { href: '/categories', label: '学科分类' },
      { href: '/blog', label: '最近更新' },
    ]}
  >
    {tagCounts.length > 0 ? (
      <>
        {popularTags.length > 0 && (
          <section class="taxonomy-section" aria-label="热门标签">
            <h2 class="taxonomy-section-title">热门标签</h2>
            <div class="tag-cloud">
              {popularTags.map(({ tag, count }) => (
                <a
                  href={`/tags/${encodeURIComponent(tag)}`}
                  class="tag-pill"
                  style={`--tag-ratio: ${Math.max(0.55, count / maxPopularCount)}`}
                  aria-label={`查看标签 ${tag}，共 ${count} 篇文章`}
                >
                  <span class="tag-pill-name">{tag}</span>
                  <span class="tag-pill-count">{count}</span>
                </a>
              ))}
            </div>
          </section>
        )}

        <section class="taxonomy-section" aria-label="所有标签">
          <h2 class="taxonomy-section-title">所有标签</h2>
          <div class="taxonomy-grid">
            {tagsByAlpha.map(({ tag, count }) => (
              <a
                href={`/tags/${encodeURIComponent(tag)}`}
                class="taxonomy-card"
                aria-label={`查看标签 ${tag}，共 ${count} 篇文章`}
              >
                <h3 class="taxonomy-name">{tag}</h3>
                <p class="tag-description">{count} 篇文章</p>
              </a>
            ))}
          </div>
        </section>
      </>
    ) : (
      <CollectionEmptyState
        message="暂无标签"
        actionHref="/blog"
        actionLabel="浏览文章"
      />
    )}
  </CollectionPageShell>
</Layout>

<style>
  .taxonomy-section {
    margin-bottom: 1.75rem;
  }

  .taxonomy-section-title {
    margin: 0 0 0.875rem;
    color: var(--dark);
    font-size: 1.125rem;
    font-weight: 700;
  }

  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .tag-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.45rem 0.75rem;
    border: 1px solid var(--lightgray);
    border-radius: 9999px;
    text-decoration: none;
    background: var(--light);
    transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }

  .tag-pill:hover {
    border-color: var(--secondary);
    transform: translateY(-1px);
    box-shadow: 0 6px 16px rgba(0, 0, 0, 0.08);
  }

  .tag-pill:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--secondary) 45%, transparent);
    outline-offset: 2px;
  }

  .tag-pill-name {
    color: var(--dark);
    font-size: calc(0.82rem + (var(--tag-ratio) - 0.55) * 0.35rem);
    font-weight: 600;
    line-height: 1;
  }

  .tag-pill-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.4rem;
    height: 1.1rem;
    padding: 0 0.3rem;
    border-radius: 9999px;
    background: var(--secondary);
    color: white;
    font-size: 0.68rem;
    font-weight: 700;
    line-height: 1;
  }

  .taxonomy-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .taxonomy-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1rem;
    background: var(--light);
    border: 1px solid var(--lightgray);
    border-radius: 0.75rem;
    text-decoration: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
  }

  .taxonomy-card:hover {
    border-color: var(--secondary);
    transform: translateY(-2px);
    box-shadow: 0 8px 22px rgba(0, 0, 0, 0.08);
  }

  .taxonomy-card:focus-visible {
    outline: 2px solid color-mix(in srgb, var(--secondary) 45%, transparent);
    outline-offset: 2px;
  }

  .taxonomy-name {
    margin: 0;
    color: var(--dark);
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.35;
  }

  .tag-description {
    margin: 0;
    color: var(--gray);
    font-size: 0.85rem;
  }

  @media (max-width: 1199px) {
    .taxonomy-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 1023px) {
    .taxonomy-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 767px) {
    .taxonomy-section-title {
      font-size: 1rem;
    }

    .taxonomy-grid {
      grid-template-columns: 1fr;
    }

    .tag-pill {
      padding: 0.4rem 0.65rem;
    }
  }
</style>
