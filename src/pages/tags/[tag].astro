---
/**
 * 标签文章列表页
 *
 * 修复说明：
 * `getStaticPaths()` 里的 params 必须传原始 tag，不能提前 encodeURIComponent，
 * 否则 dev/route matching 下会出现标签链接 404。
 */
export const prerender = true;

import Layout from '../../layout/Layout.astro';
import MainNav from '../../components/MainNav.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import CollectionPageShell from '../../components/CollectionPageShell.astro';
import CollectionEmptyState from '../../components/CollectionEmptyState.astro';
import { db } from '../../db/client';
import { articleTags, articles, type Article } from '../../db/schema';
import { and, eq } from 'drizzle-orm';
import { getArticlesByTag } from '../../lib/articles';

interface TagPageProps {
  decodedTag: string;
  taggedArticles: Article[];
}

export async function getStaticPaths() {
  console.log('[BUILD] Starting static path generation for tags...');

  const allTags = await db
    .selectDistinct({ tag: articleTags.tag })
    .from(articleTags)
    .innerJoin(articles, eq(articleTags.articleId, articles.id))
    .where(
      and(
        eq(articles.status, 'published'),
        eq(articles.isDeleted, false),
      ),
    );

  console.log(`[BUILD] Found ${allTags.length} published tags`);

  const paths = await Promise.all(
    allTags.map(async ({ tag }) => {
      const taggedArticles = await getArticlesByTag(tag);

      return {
        params: { tag },
        props: {
          decodedTag: tag,
          taggedArticles,
        } as TagPageProps,
      };
    }),
  );

  console.log('[BUILD] Tag static paths generated');
  return paths;
}

const { decodedTag, taggedArticles } = Astro.props as TagPageProps;
---

<Layout
  title={`标签: ${decodedTag} - Openeducation`}
  description={`标签「${decodedTag}」下共有 ${taggedArticles.length} 篇已发布文章`}
>
  <MainNav />

  <CollectionPageShell
    backHref="/tags"
    backLabel="返回标签页"
    icon="🏷️"
    title={decodedTag}
    subtitle={`围绕「${decodedTag}」聚合的相关文章`}
    meta={`共 ${taggedArticles.length} 篇文章`}
    quickLinks={[
      { href: '/articles', label: '全部文章' },
      { href: '/categories', label: '学科分类' },
    ]}
  >
    {taggedArticles.length > 0 ? (
      <section class="collection-articles-section" aria-label={`${decodedTag} 标签下的文章列表`}>
        <div class="collection-articles-grid">
          {taggedArticles.map((article) => (
            <ArticleCard article={article} />
          ))}
        </div>
      </section>
    ) : (
      <CollectionEmptyState
        message={`当前没有找到标签「${decodedTag}」下的文章`}
        actionHref="/tags"
        actionLabel="返回标签页"
      />
    )}
  </CollectionPageShell>
</Layout>
