---
/**
 * Landing Page - 欢迎页
 * 参考 https://openeducation.vercel.app/
 * 功能：星空背景 + 知识图谱 + 点击跳转到博客
 */
// 强制静态预渲染
export const prerender = true;

import '../styles/landing.css';
import '../styles/quartz/variables.css';
import '../styles/quartz/darkmode.css';
import QuartzGraph from '../components/quartz/QuartzGraph';

const title = 'I want to learn';
const subtitle = 'Ship your Second Brain into the Cyber-Space';
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <!-- Google Tag Manager -->
  <script is:inline>
    (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-WSSXP26S');
  </script>
  <!-- End Google Tag Manager -->
  
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={subtitle}>
  
  <!-- 防止主题闪烁 -->
  <script is:inline>
    (function() {
      const saved = localStorage.getItem('theme');
      const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
      const theme = saved || (prefersDark ? 'dark' : 'light');
      document.documentElement.setAttribute('saved-theme', theme);
    })();
  </script>
</head>
<body>
  <!-- Google Tag Manager (noscript) -->
  <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-WSSXP26S"
  height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
  <!-- End Google Tag Manager (noscript) -->
  <div class="landing-container">
    <!-- 星空背景 -->
    <div class="stars"></div>
    <div class="twinkling"></div>
    <div class="clouds"></div>

    <!-- 知识图谱 - 可见时才加载，减少首屏 JS -->
    <div class="graph-container">
      <QuartzGraph 
        client:visible
        isGlobal={true}
        height={600}
        showTitle={false}
        globalGraph={{ depth: -1, enableRadial: true, labelDisplayMode: 'priority', defaultVisibleLabelCount: 14 }}
      />
    </div>

    <div class="hero-veil" aria-hidden="true"></div>

    <!-- 内容区域 - Logo和标题 -->
    <div class="content-wrapper">
      <!-- Logo 图片 -->
      <div class="rocket-container">
        <img src="/assets/logo.png" alt="Logo" class="logo-img" />
      </div>

      <!-- 标题和副标题 -->
      <section class="title-section">
        <h1 class="main-title">{title}</h1>
        <p class="main-subtitle">{subtitle}</p>
      </section>

      <!-- 开始探索按钮 -->
      <a href="/blog" class="explore-btn">开始探索</a>
    </div>
  </div>
  
  <!-- Darkmode 脚本 -->
  <script>
    import '../scripts/quartz/darkmode.ts';
  </script>
</body>
</html>

<style>
  /* 整体布局 - 居中显示 */
  .landing-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    position: relative;
  }

  /* 内容包装器 - Logo和标题组合 */
  .content-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-decoration: none;
    position: relative;
    z-index: 20;
    max-width: min(720px, calc(100vw - 2rem));
    padding: 2rem 1.5rem;
    box-sizing: border-box;
  }

  .hero-veil {
    position: absolute;
    inset: 0;
    z-index: 4;
    pointer-events: none;
    background:
      radial-gradient(circle at 50% 42%, rgba(5, 10, 24, 0.46) 0%, rgba(5, 10, 24, 0.26) 24%, rgba(5, 10, 24, 0.1) 44%, rgba(5, 10, 24, 0) 68%);
  }

  /* 火箭容器 */
  .rocket-container {
    display: flex;
    justify-content: center;
    align-items: center;
    margin-bottom: 1rem;
    cursor: pointer;
    transition: transform 0.3s ease;
  }

  .rocket-container:hover {
    transform: scale(1.05);
  }

  .logo-img {
    width: 160px;
    height: auto;
    filter: drop-shadow(0 0 20px rgba(168, 85, 247, 0.4));
    animation: float 3s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-10px);
    }
  }

  .title-section {
    text-align: center;
    padding: 1rem 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .main-title {
    font-size: 3rem;
    font-weight: 700;
    background: linear-gradient(to right, #a855f7, #c084fc, #ec4899);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin: 0;
    line-height: 1.2;
  }

  .main-subtitle {
    font-size: 1.375rem;
    color: rgba(255, 255, 255, 0.8);
    margin: 0;
  }

  /* 开始探索按钮 */
  .explore-btn {
    display: inline-block;
    margin-top: 2rem;
    padding: 0.875rem 2.5rem;
    font-size: 1.125rem;
    font-weight: 600;
    color: #fff;
    background: linear-gradient(135deg, #9333ea, #db2777);
    border: none;
    border-radius: 50px;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 4px 20px rgba(147, 51, 234, 0.4);
  }

  .explore-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 6px 30px rgba(147, 51, 234, 0.6);
  }

  .explore-btn:active {
    transform: translateY(-1px);
  }

  @media (max-width: 768px) {
    .hero-veil {
      background:
        radial-gradient(circle at 50% 44%, rgba(5, 10, 24, 0.4) 0%, rgba(5, 10, 24, 0.22) 30%, rgba(5, 10, 24, 0.08) 52%, rgba(5, 10, 24, 0) 74%);
    }

    .logo-img {
      width: 130px;
    }
    
    .main-title {
      font-size: 2rem;
    }
    
    .main-subtitle {
      font-size: 1.125rem;
    }

    .explore-btn {
      padding: 0.75rem 2rem;
      font-size: 1rem;
    }
  }

  @media (max-width: 480px) {
    .logo-img {
      width: 100px;
    }
    
    .main-title {
      font-size: 1.75rem;
    }
    
    .main-subtitle {
      font-size: 1rem;
      padding: 0 1rem;
    }

    .explore-btn {
      padding: 0.625rem 1.5rem;
      font-size: 0.9rem;
    }
  }
</style>
