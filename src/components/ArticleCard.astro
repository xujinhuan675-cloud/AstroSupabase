---
/**
 * 文章卡片组件 - 移动端优化版
 * 响应式布局，移动端单列显示
 */
import type { Article } from '../db/schema';

export interface Props {
  article: Article;
}

const { article } = Astro.props;
const { id, title, updatedAt, content, excerpt: rawExcerpt, readingTime, category } = article;
const date = new Date(updatedAt).toLocaleDateString('zh-CN', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

const CATEGORY_LABELS: Record<string, string> = {
  math: '数学',
  physics: '物理',
  chemistry: '化学',
  biology: '生物',
  computer: '计算机',
  literature: '文学',
};

const plainContent = content
  .replace(/```[\s\S]*?```/g, ' ')
  .replace(/`[^`]*`/g, ' ')
  .replace(/!\[.*?\]\(.*?\)/g, ' ')
  .replace(/\[([^\]]+)\]\([^)]+\)/g, '$1')
  .replace(/^#{1,6}\s+/gm, '')
  .replace(/[*_~>-]/g, ' ')
  .replace(/\s+/g, ' ')
  .trim();

const excerptSource = (rawExcerpt || plainContent).trim();
const excerpt = excerptSource.length > 120 ? `${excerptSource.slice(0, 120)}…` : excerptSource;
const fallbackReadMinutes = Math.max(1, Math.ceil(plainContent.length / 450));
const readingLabel = readingTime || `${fallbackReadMinutes} 分钟阅读`;
const categoryLabel = category ? (CATEGORY_LABELS[category] ?? category) : null;
---

<article class="article-card">
  <div class="card-content">
    <div class="card-meta">
      <span class="meta-item date">{date}</span>
      <span class="meta-separator">•</span>
      <span class="meta-item reading-time">{readingLabel}</span>
      {categoryLabel && (
        <>
          <span class="meta-separator">•</span>
          <span class="category-chip">{categoryLabel}</span>
        </>
      )}
    </div>
    <h2 class="card-title">
      <a href={`/articles/${id}`}>
        {title}
      </a>
    </h2>
    <p class="card-excerpt">{excerpt}</p>
    <a href={`/articles/${id}`} class="read-more">
      阅读更多
      <svg class="arrow-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
      </svg>
    </a>
  </div>
</article>

<style>
  .article-card {
    background: var(--light);
    border-radius: 0.75rem;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    overflow: hidden;
    transition: box-shadow 0.3s ease, transform 0.2s ease;
  }

  .article-card:hover {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.12);
  }

  /* 触摸反馈 */
  @media (hover: none) {
    .article-card:active {
      transform: scale(0.98);
    }
  }

  .card-content {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  /* 移动端内边距调整 */
  @media (max-width: 639px) {
    .card-content {
      padding: 1rem;
    }
  }

  .card-meta {
    display: flex;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin: 0;
    line-height: 1.45;
    font-size: 0.8125rem;
    color: var(--gray);
  }

  .meta-item {
    color: var(--gray);
  }

  .meta-separator {
    color: var(--gray);
    opacity: 0.65;
  }

  .category-chip {
    display: inline-flex;
    align-items: center;
    padding: 0.125rem 0.5rem;
    border-radius: 9999px;
    font-size: 0.75rem;
    color: var(--secondary);
    background: var(--highlight);
    font-weight: 600;
  }

  .card-title {
    font-size: 1.25rem;
    font-weight: 700;
    margin: 0;
    line-height: 1.4;
    color: var(--dark);
    word-break: break-word;
  }

  /* 移动端标题样式 */
  @media (max-width: 639px) {
    .card-title {
      font-size: 1.125rem; /* 18px */
      line-height: 1.5;
    }
  }

  .card-title a {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s ease;
    display: block;
    min-height: 0;
  }

  @media (max-width: 639px) {
    .card-title a {
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
  }

  .card-title a:hover {
    color: var(--secondary);
  }

  .card-excerpt {
    color: var(--gray);
    font-size: 0.9375rem;
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 639px) {
    .card-excerpt {
      font-size: 0.875rem;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
  }

  .read-more {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    margin-top: auto;
    color: var(--secondary);
    font-weight: 500;
    text-decoration: none;
    font-size: 0.9375rem;
    min-height: 44px;
    padding: 0.5rem 0;
    transition: opacity 0.2s ease;
  }

  .read-more:hover {
    opacity: 0.8;
  }

  .arrow-icon {
    width: 1rem;
    height: 1rem;
    transition: transform 0.2s ease;
  }

  .read-more:hover .arrow-icon {
    transform: translateX(4px);
  }

  /* 移除 popover 脚本自动标记的 internal 链接样式 */
  .article-card a.internal {
    background: transparent !important;
    padding: 0 !important;
    border-radius: 0 !important;
  }

  .article-card h2 a.internal {
    color: var(--dark);
  }

  .article-card a.internal:hover {
    color: var(--secondary);
  }
</style>
